{
  "name": "know-a-song",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/shared",
    "packages/database"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,scss,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,scss,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.0.0",
  "overrides": {
    "postcss": "8.5.16",
    "esbuild": "0.28.1",
    "multer": "1.4.5-lts.2",
    "tar": "7.5.19"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
